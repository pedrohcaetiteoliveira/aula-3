import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner e = new Scanner(System.in);
        System.out.println(" digite um número inteiro");
        int numero = e.nextInt();

        if (numero > 20){
            int metade = numero / 2;
            System.out.println("A metade do número é:"+ metade);
        }

        e.close();
    }
}
